
<div className="container">
  <% bookInfo.forEach(book => { %>

    <a href="/favourites/<%= book.name %>" class="book_card_link">
      
      <div class="book_card">
        <div class="book_rid">
          <div class="name center"><%= book.name %></div>
          <div class="author center"><%= book.author %></div>
          <div class="genre center"><%= book.genre %></div>
          <div class="description"><%= book.description %></div>
          <div class="pages "><%= book.pages %></div>
        </div>
      </div>

    </a> <% }) %>
</div>